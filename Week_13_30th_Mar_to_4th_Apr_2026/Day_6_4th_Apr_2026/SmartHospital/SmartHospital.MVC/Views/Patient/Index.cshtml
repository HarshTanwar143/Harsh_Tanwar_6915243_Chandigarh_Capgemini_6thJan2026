@model List<AppointmentViewModel>
@{ ViewData["Title"] = "Patient Dashboard"; }
@{ var name = Context.Session.GetString("UserName"); }
<h4 class="fw-bold mb-1"><i class="bi bi-person-heart me-2 text-primary"></i>Welcome, @name!</h4>
<p class="text-muted mb-4">Manage your appointments and view your medical records.</p>
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card stat-card p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="small opacity-75">Total Appointments</div><div class="fs-2 fw-bold">@Model.Count</div></div>
        <i class="bi bi-calendar-check fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card green p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="small opacity-75">Completed</div><div class="fs-2 fw-bold">@Model.Count(a=>a.Status=="Completed")</div></div>
        <i class="bi bi-check-circle fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card blue p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="small opacity-75">Upcoming</div><div class="fs-2 fw-bold">@Model.Count(a=>a.Status=="Booked")</div></div>
        <i class="bi bi-clock fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
</div>
<div class="d-flex gap-3 mb-4">
  <a href="/Patient/BookAppointment" class="btn btn-primary btn-lg">
    <i class="bi bi-calendar-plus me-2"></i>Book New Appointment
  </a>
  <a href="/Patient/Bills" class="btn btn-outline-primary btn-lg">
    <i class="bi bi-receipt me-2"></i>View My Bills
  </a>
</div>
<div class="card">
  <div class="card-body">
    <h6 class="fw-bold mb-3">Recent Appointments</h6>
    @if (!Model.Any())
    {
      <p class="text-muted">No appointments yet. <a href="/Patient/BookAppointment">Book your first appointment!</a></p>
    }
    else
    {
      <table class="table table-hover">
        <thead><tr><th>Doctor</th><th>Department</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        @foreach (var a in Model.Take(5))
        {
          <tr>
            <td>Dr. @a.DoctorName</td>
            <td>@a.DepartmentName</td>
            <td>@a.AppointmentDate.ToString("dd MMM yyyy")</td>
            <td><span class="badge @(a.Status=="Completed"?"bg-success":a.Status=="Cancelled"?"bg-danger":"bg-primary")">@a.Status</span></td>
            <td>
              @if (a.HasPrescription)
              { <a href="/Patient/ViewPrescription?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-prescription"></i> Rx</a> }
              @if (a.HasBill)
              { <a href="/Patient/ViewBill?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-success"><i class="bi bi-receipt"></i> Bill</a> }
            </td>
          </tr>
        }
        </tbody>
      </table>
    }
  </div>
</div>
