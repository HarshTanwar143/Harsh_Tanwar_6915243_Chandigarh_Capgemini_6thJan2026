@{ ViewData["Title"] = "Admin Dashboard"; }
<h2>Admin Dashboard</h2>
<div class="row mt-4">
    <div class="col-md-3"><div class="card text-white bg-primary mb-3"><div class="card-body"><h5 class="card-title">Manage Books</h5><a asp-action="Books" class="btn btn-light btn-sm">Go</a></div></div></div>
    <div class="col-md-3"><div class="card text-white bg-success mb-3"><div class="card-body"><h5 class="card-title">Manage Orders</h5><a asp-action="Orders" class="btn btn-light btn-sm">Go</a></div></div></div>
    <div class="col-md-3"><div class="card text-white bg-warning mb-3"><div class="card-body"><h5 class="card-title">Categories</h5><a asp-action="Categories" class="btn btn-light btn-sm">Go</a></div></div></div>
    <div class="col-md-3"><div class="card text-white bg-danger mb-3"><div class="card-body"><h5 class="card-title">Sales Report</h5><a asp-action="Reports" class="btn btn-light btn-sm">Go</a></div></div></div>
</div>