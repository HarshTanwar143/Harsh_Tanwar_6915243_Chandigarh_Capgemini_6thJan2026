@model BookFormModel
@{ ViewData["Title"] = "Add New Book"; var categories = ViewBag.Categories as List<CategoryView> ?? new(); var authors = ViewBag.Authors as List<AuthorView> ?? new(); var publishers = ViewBag.Publishers as List<PublisherView> ?? new(); }
<h2>Add New Book</h2>
<div class="row"><div class="col-md-6">
<form asp-action="CreateBook" method="post">
    <div class="mb-3"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /></div>
    <div class="mb-3"><label asp-for="ISBN" class="form-label"></label><input asp-for="ISBN" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" type="number" step="0.01" /></div>
    <div class="mb-3"><label asp-for="Stock" class="form-label"></label><input asp-for="Stock" class="form-control" type="number" /></div>
    <div class="mb-3"><label asp-for="CategoryId" class="form-label">Category</label><select asp-for="CategoryId" class="form-select"><option value="">-- Select --</option>@foreach (var c in categories) { <option value="@c.CategoryId">@c.Name</option> }</select></div>
    <div class="mb-3"><label asp-for="AuthorId" class="form-label">Author</label><select asp-for="AuthorId" class="form-select"><option value="">-- Select --</option>@foreach (var a in authors) { <option value="@a.AuthorId">@a.Name</option> }</select></div>
    <div class="mb-3"><label asp-for="PublisherId" class="form-label">Publisher</label><select asp-for="PublisherId" class="form-select"><option value="">-- Select --</option>@foreach (var p in publishers) { <option value="@p.PublisherId">@p.Name</option> }</select></div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Books" class="btn btn-secondary">Cancel</a>
</form>
</div></div>