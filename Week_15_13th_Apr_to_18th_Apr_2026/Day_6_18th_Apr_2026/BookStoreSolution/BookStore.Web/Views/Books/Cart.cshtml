@model List<CartItem>
@{ ViewData["Title"] = "Cart"; }
<h2>Shopping Cart</h2>
@if (Model.Any())
{
    <table class="table"><thead><tr><th>Book</th><th>Price</th><th>Qty</th><th>Subtotal</th></tr></thead>
    <tbody>@foreach (var item in Model) { <tr><td>@item.Title</td><td>Rs. @item.Price</td><td>@item.Qty</td><td>Rs. @(item.Price * item.Qty)</td></tr> }</tbody>
    <tfoot><tr><th colspan="3">Total</th><th>Rs. @Model.Sum(i => i.Price * i.Qty)</th></tr></tfoot></table>
    <form asp-action="Checkout" method="post"><button type="submit" class="btn btn-primary">Place Order</button></form>
}
else { <p>Your cart is empty. <a asp-controller="Books" asp-action="Index">Browse books</a></p> }