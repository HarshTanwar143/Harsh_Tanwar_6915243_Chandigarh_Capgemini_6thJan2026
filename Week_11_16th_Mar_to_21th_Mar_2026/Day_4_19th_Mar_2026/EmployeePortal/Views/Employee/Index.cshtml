@model IEnumerable<EmployeePortal.Models.Employee>

<style>
    .page-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }

    .page-title {
        font-size: 34px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 28px;
    }

    /* TOOLBAR */
    .toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .search-wrap {
        flex: 1;
        min-width: 200px;
        position: relative;
    }

        .search-wrap svg {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

    .search-input {
        width: 100%;
        background: var(--surface2) !important;
        border: 1px solid var(--border) !important;
        border-radius: 8px !important;
        padding: 10px 14px 10px 38px !important;
        color: var(--text) !important;
        font-family: 'Outfit', sans-serif !important;
        font-size: 14px !important;
        outline: none;
        transition: border-color .15s;
    }

        .search-input:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px rgba(0,212,170,0.1) !important;
        }

        .search-input::placeholder {
            color: var(--muted) !important;
        }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        background: var(--accent);
        color: #0d1117 !important;
        border: none;
        border-radius: 8px;
        font-family: 'Outfit', sans-serif;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none !important;
        transition: background .15s, transform .15s, box-shadow .15s;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #00b892;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,212,170,0.25);
        }

    /* TABLE */
    .emp-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .emp-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

        .emp-table thead tr {
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
        }

        .emp-table thead th {
            padding: 13px 20px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10.5px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--muted);
            font-weight: 400;
            text-align: left;
        }

        .emp-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }

            .emp-table tbody tr:last-child {
                border-bottom: none;
            }

            .emp-table tbody tr:hover {
                background: var(--surface2);
            }

        .emp-table tbody td {
            padding: 15px 20px;
            font-size: 14px;
            color: var(--text);
            vertical-align: middle;
        }

    /* Name cell with avatar */
    .emp-cell-name {
        display: flex;
        align-items: center;
        gap: 11px;
    }

    .emp-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--accent), var(--blue));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
        color: #0d1117;
        flex-shrink: 0;
    }

    /* Department badge */
    .dept-tag {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        background: rgba(56,139,253,0.12);
        border: 1px solid rgba(56,139,253,0.25);
        color: var(--blue);
    }

    /* Salary */
    .salary-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: var(--accent);
    }

    /* Action buttons */
    .action-cell {
        display: flex;
        gap: 8px;
    }

    .btn-edit-sm {
        padding: 5px 14px;
        border-radius: 6px;
        font-size: 12.5px;
        font-weight: 500;
        background: rgba(210,153,34,0.12);
        border: 1px solid rgba(210,153,34,0.3);
        color: #d29922;
        text-decoration: none !important;
        transition: background .15s, transform .15s;
    }

        .btn-edit-sm:hover {
            background: rgba(210,153,34,0.22);
            transform: translateY(-1px);
            color: #d29922;
        }

    .btn-del-sm {
        padding: 5px 14px;
        border-radius: 6px;
        font-size: 12.5px;
        font-weight: 500;
        background: rgba(248,81,73,0.1);
        border: 1px solid rgba(248,81,73,0.28);
        color: var(--danger);
        text-decoration: none !important;
        transition: background .15s, transform .15s;
    }

        .btn-del-sm:hover {
            background: rgba(248,81,73,0.2);
            transform: translateY(-1px);
            color: var(--danger);
        }

    @@media (max-width: 600px) {
        .page-title {
            font-size: 26px;
        }

        .emp-table thead {
            display: none;
        }

        .emp-table tbody td {
            display: block;
            padding: 8px 16px;
        }

        .emp-table tbody tr {
            display: block;
            padding: 12px 0;
        }
    }
</style>

<div class="page-eyebrow">Management</div>
<div class="page-title">Employee List</div>

<div class="toolbar">
    <!-- Search -->
    <form method="get" class="search-wrap">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
        <input type="text" name="search" class="search-input" placeholder="Search by Name or Department..." />
    </form>

    <!-- Add Employee — Admin only -->
    @if (User.IsInRole("Admin"))
    {
        <a class="btn-add" asp-action="Create">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Add Employee
        </a>
    }
</div>

<div class="emp-table-wrap">
    <table class="emp-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Salary</th>
                @if (User.IsInRole("Admin"))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="emp-cell-name">
                            <div class="emp-avatar">@item.Name?.Substring(0, 1).ToUpper()</div>
                            @item.Name
                        </div>
                    </td>
                    <td><span class="dept-tag">@item.Department</span></td>
                    <td><span class="salary-val">@item.Salary</span></td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td>
                            <div class="action-cell">
                                <a class="btn-edit-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                <a class="btn-del-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
