<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmployeePortal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EmployeePortal.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:       #0d1117;
            --surface:  #161b22;
            --surface2: #21262d;
            --border:   #30363d;
            --accent:   #00d4aa;
            --text:     #e6edf3;
            --muted:    #7d8590;
            --danger:   #f85149;
            --blue:     #388bfd;
        }
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            background: var(--bg) !important;
            color: var(--text) !important;
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            margin: 0;
        }

        /* NAV */
        .ep-nav {
            position: sticky; top: 0; z-index: 200;
            height: 56px;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 32px;
            background: rgba(13,17,23,0.94);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
        }
        .ep-brand { display:flex; align-items:center; gap:10px; text-decoration:none !important; }
        .ep-brand-logo {
            width:30px; height:30px; border-radius:7px;
            background: linear-gradient(135deg, var(--accent) 0%, #388bfd 100%);
            display:flex; align-items:center; justify-content:center;
            font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500; color:#0d1117;
        }
        .ep-brand-text { font-size:15px; font-weight:600; color:var(--text); letter-spacing:-0.01em; }

        .ep-links { display:flex; align-items:center; gap:2px; }
        .ep-link {
            padding:6px 13px; border-radius:6px; font-size:13.5px; font-weight:400;
            color:var(--muted); text-decoration:none !important;
            transition: color .15s, background .15s;
        }
        .ep-link:hover { color:var(--text); background:var(--surface2); }

        .ep-right { display:flex; align-items:center; gap:6px; }
        /* Make _LoginPartial links inherit the style */
        .ep-right a, .ep-right button, .ep-right form { all:unset; cursor:pointer; }
        .ep-right a, .ep-right button {
            display:inline-block;
            padding:6px 13px; border-radius:6px; font-family:'Outfit',sans-serif;
            font-size:13.5px; font-weight:400; color:var(--muted);
            text-decoration:none !important; background:transparent;
            border:none; cursor:pointer; transition:color .15s, background .15s;
        }
        .ep-right a:hover, .ep-right button:hover { color:var(--text); background:var(--surface2); }

        /* CONTENT */
        .ep-page { max-width:1140px; margin:0 auto; padding:44px 28px 80px; }

        /* FOOTER */
        .ep-footer {
            border-top:1px solid var(--border);
            padding:18px 32px;
            font-family:'JetBrains Mono',monospace;
            font-size:12px; color:var(--muted);
            display:flex; gap:14px;
        }
        .ep-footer a { color:var(--accent); text-decoration:none; }

        /* GLOBAL FORM & BTN OVERRIDES */
        .form-control, .form-select {
            background: var(--surface2) !important;
            border: 1px solid var(--border) !important;
            color: var(--text) !important;
            border-radius: 8px !important;
            font-family: 'Outfit', sans-serif !important;
            font-size: 14px !important;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px rgba(0,212,170,0.12) !important;
        }
        .form-control::placeholder { color: var(--muted) !important; }
        label { color: var(--muted); font-size:13px; font-weight:500; }

        .btn { border-radius:7px !important; font-family:'Outfit',sans-serif !important; font-weight:500 !important; font-size:13.5px !important; }
        .btn-success { background:var(--accent) !important; border-color:var(--accent) !important; color:#0d1117 !important; }
        .btn-success:hover { background:#00b892 !important; border-color:#00b892 !important; }
        .btn-warning { background:#d29922 !important; border-color:#d29922 !important; color:#0d1117 !important; }
        .btn-warning:hover { background:#b8831a !important; }
        .btn-danger { background:var(--danger) !important; border-color:var(--danger) !important; }

        h1, h2, h3, h4, h5, h6 { font-family:'Outfit',sans-serif; font-weight:700; color:var(--text); }
    </style>
</head>
<body>
    <header>
        <nav class="ep-nav">
            <a class="ep-brand" asp-controller="Home" asp-action="Index">
                <div class="ep-brand-logo">EP</div>
                <span class="ep-brand-text">EmployeePortal</span>
            </a>

            <div class="ep-links">
                <a class="ep-link" asp-controller="Home" asp-action="Index">Home</a>
                <a class="ep-link" asp-controller="Employee" asp-action="Index">Employees</a>
                <a class="ep-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
            </div>

            <div class="ep-right">
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>

    <div class="ep-page">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="ep-footer">
        <span>&copy; 2026 EmployeePortal</span>
        <span>|</span>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
