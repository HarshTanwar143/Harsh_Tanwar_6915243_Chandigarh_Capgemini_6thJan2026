@page
@model EventBookingWeb.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle display-3 text-danger"></i>
    <h2 class="fw-bold mt-3">Something went wrong</h2>
    <p class="text-muted">An unexpected error has occurred. Please try again.</p>
    <a href="/" class="btn btn-primary mt-2">Go Home</a>
</div>
