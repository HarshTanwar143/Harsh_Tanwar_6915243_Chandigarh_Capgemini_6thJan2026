@page
@model EventBookingWeb.Pages.Events.MyBookingsModel
@{
    ViewData["Title"] = "My Bookings";
}

<input type="hidden" id="apiBase" value="@Model.ApiBase" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-ticket-perforated me-2 text-primary"></i>My Bookings</h3>
    <a href="/Events/Index" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus me-1"></i>Book More</a>
</div>

<div id="alertBox" class="alert d-none" role="alert"></div>
<div id="loadingSpinner" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="text-muted mt-2">Loading your bookings...</p>
</div>
<div id="noBookings" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x display-3 text-muted"></i>
    <p class="fs-5 text-muted mt-3">You haven't booked any events yet.</p>
    <a href="/Events/Index" class="btn btn-primary mt-2">Browse Events</a>
</div>
<div id="bookingsContainer" class="row g-4"></div>

@section Scripts {
<script>
    const API = document.getElementById('apiBase').value;

    function escHtml(str) {
        if (!str) return '';
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }

    async function loadMyBookings() {
        const token = localStorage.getItem('token');
        if (!token) { window.location.href = '/Auth/Login'; return; }

        try {
            const res = await fetch(API + '/api/bookings/my', {
                headers: { 'Authorization': 'Bearer ' + token }
            });

            document.getElementById('loadingSpinner').style.display = 'none';

            if (res.status === 401) { window.location.href = '/Auth/Login'; return; }

            const bookings = await res.json();

            if (!bookings || bookings.length === 0) {
                document.getElementById('noBookings').classList.remove('d-none');
                return;
            }

            const container = document.getElementById('bookingsContainer');
            bookings.forEach(function(b) {
                const date = new Date(b.eventDate);
                const bookedAt = new Date(b.bookedAt);
                const isPast = date < new Date();

                const cancelBtn = !isPast ? '<button class="btn btn-outline-danger btn-sm mt-auto" onclick="cancelBooking(' + b.id + ')"><i class="bi bi-x-circle me-1"></i>Cancel Booking</button>' : '';

                container.insertAdjacentHTML('beforeend',
                    '<div class="col-md-4" id="bookingCard-' + b.id + '">' +
                    '<div class="card h-100 border-0 shadow-sm"><div class="card-body d-flex flex-column">' +
                    '<div class="d-flex justify-content-between mb-2">' +
                    '<span class="badge ' + (isPast ? 'bg-secondary' : 'bg-success') + '">' + (isPast ? 'Completed' : 'Upcoming') + '</span>' +
                    '<small class="text-muted">' + date.toLocaleDateString('en-IN') + '</small></div>' +
                    '<h5 class="fw-bold">' + escHtml(b.eventTitle) + '</h5>' +
                    '<p class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>' + escHtml(b.eventLocation) + '</p>' +
                    '<p class="text-muted small mb-1"><i class="bi bi-ticket me-1"></i>' + b.seatsBooked + ' seat(s) booked</p>' +
                    '<p class="text-muted small mb-3"><i class="bi bi-clock-history me-1"></i>Booked on ' + bookedAt.toLocaleDateString('en-IN') + '</p>' +
                    cancelBtn +
                    '</div></div></div>');
            });

        } catch (e) {
            document.getElementById('loadingSpinner').style.display = 'none';
            const box = document.getElementById('alertBox');
            box.textContent = 'Failed to load bookings.';
            box.className = 'alert alert-danger';
        }
    }

    async function cancelBooking(id) {
        if (!confirm('Are you sure you want to cancel this booking?')) return;
        const token = localStorage.getItem('token');
        try {
            const res = await fetch(API + '/api/bookings/' + id, {
                method: 'DELETE',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (res.ok || res.status === 204) {
                const card = document.getElementById('bookingCard-' + id);
                if (card) card.remove();
                const box = document.getElementById('alertBox');
                box.textContent = 'Booking cancelled successfully.';
                box.className = 'alert alert-success';
                setTimeout(function() { box.className = 'alert d-none'; }, 3000);
            }
        } catch (e) {
            alert('An error occurred. Please try again.');
        }
    }

    loadMyBookings();
</script>
}
